# CS2 Demo Player -- environment configuration.
# Copy to ".env" (compose auto-loads it) and fill in. NEVER commit your real .env.
# EVERYTHING here is optional: with none of it set, the app runs in local single-user mode
# exactly as it always has (no login, no data isolation).

# ---- Authentication (Steam OpenID 2.0) --------------------------------------
# Set PUBLIC_BASE_URL to turn ON Steam login. It must be the URL users actually hit
# (used to build the OpenID return_to). Behind a reverse proxy this is your public https URL.
# OpenID login needs only PUBLIC_BASE_URL + SECRET_KEY -- NOT a Steam API key.
PUBLIC_BASE_URL=

# Flask session signing key. REQUIRED in production (otherwise an ephemeral key is used and
# everyone gets logged out on restart). Generate one:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# OPTIONAL. Only fetches each user's display name + avatar (GetPlayerSummaries). Login works
# without it -- users just show up by SteamID. Get a key at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# Set to 1 to REQUIRE login before any data is visible (recommended once you go multi-user).
# Unset/0 = login is available but anonymous browsing still works.
AUTH_REQUIRED=0

# Set to 1 when served over HTTPS so the session cookie is marked Secure (HTTPS-only).
SESSION_COOKIE_SECURE=0

# ---- Admin + subscription tiers ---------------------------------------------
# Comma-separated SteamID64s that get the admin panel (instance stats + grant/revoke Pro).
ADMIN_STEAM_IDS=

# 0 = everyone has every feature (default). 1 = enforce the Free/Pro split: Free gets 2D replay +
# basic analytics; 3D, utility/nade tools, advanced analytics/trends, goals and teams require Pro
# (admins always Pro). Grant Pro per-user from the admin panel (manual until billing is wired up).
TIERS_ENABLED=0

# How many demos a Free user may store (only enforced when TIERS_ENABLED=1; Pro/admin = unlimited).
FREE_UPLOAD_LIMIT=5

# ---- Storage / limits -------------------------------------------------------
# In Docker these default to /data/* (a mounted volume). Override for a non-Docker host.
# DATA_DIR=/data
# SQLITE_PATH=/data/cs2dp.sqlite
# CACHE_DIR=/data/cache
# UPLOAD_DIR=/data/uploads
# NADES_DIR=/data/nades
MAX_UPLOAD_MB=2048
MAX_VIDEO_UPLOAD_MB=100

# Discard the raw .dem after parsing (recommended for a shared host -- a CS2 demo is 300-500MB and
# the app only needs the small parsed cache to replay/analyze). Set 0 to delete, 1 to keep.
# Trade-off: with 0, a future parser upgrade can't re-process old demos from disk -- users re-upload.
KEEP_DEM=1

# ---- Bind (non-Docker) ------------------------------------------------------
# HOST=127.0.0.1     # 0.0.0.0 to expose on the LAN
# PORT=8770

# VantageGG — PRODUCTION env for the VPS (apex domain vantagegg.com).
# On the server: copy this to ".env" next to docker-compose.yml, then fill SECRET_KEY.
#   cp deploy/vantagegg.env.example .env
# Generate the secret ON THE SERVER (never commit a real one):
#   python3 -c "import secrets; print(secrets.token_hex(32))"

PUBLIC_BASE_URL=https://vantagegg.com   # turns ON Steam login + builds the OpenID return URL
SECRET_KEY=                              # <-- paste the generated 64-char hex here (REQUIRED)

STEAM_API_KEY=                          # optional: fetches names+avatars. Login works without it.

AUTH_REQUIRED=1                         # require Steam login before any data is visible (landing page still public)
SESSION_COOKIE_SECURE=1                 # you're on HTTPS

ADMIN_STEAM_IDS=76561198106326204       # you -> admin panel (instance stats + grant/revoke Pro)

TIERS_ENABLED=0                         # 0 = everyone gets everything. 1 = enforce Free/Pro (billing not live; grant Pro in admin)
FREE_UPLOAD_LIMIT=5

MAX_UPLOAD_MB=2048
MAX_VIDEO_UPLOAD_MB=100
KEEP_DEM=0                              # delete raw .dem after parsing (saves ~300-500 MB/demo; recommended for a host)

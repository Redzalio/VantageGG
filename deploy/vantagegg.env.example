# VantageGG — PRODUCTION env for the VPS (apex domain vantagegg.com).
# On the server: copy to ".env" next to docker-compose.yml, then fill SECRET_KEY.
#   cp deploy/vantagegg.env.example .env
# Generate the secret ON THE SERVER (never commit a real one):
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# NOTE: values are bare KEY=VALUE (no inline comments) so env_file parses them exactly.

# Turns ON Steam login + builds the OpenID return URL.
PUBLIC_BASE_URL=https://vantagegg.com

# REQUIRED — paste the generated 64-char hex (else logins reset every restart).
SECRET_KEY=

# Optional: fetches player names + avatars. Login works without it (users show by SteamID).
STEAM_API_KEY=

# 1 = require Steam login before any data is visible (the public landing page still shows).
AUTH_REQUIRED=1

# 1 = mark the session cookie Secure (you're on HTTPS).
SESSION_COOKIE_SECURE=1

# Comma-separated SteamID64s that get the admin panel.
ADMIN_STEAM_IDS=76561198106326204

# 0 = everyone gets everything. 1 = enforce Free/Pro (billing not live; grant Pro in admin).
TIERS_ENABLED=0
FREE_UPLOAD_LIMIT=5

MAX_UPLOAD_MB=2048
MAX_VIDEO_UPLOAD_MB=100

# 0 = delete the raw .dem after parsing (saves ~300-500 MB/demo; recommended for a host).
KEEP_DEM=0

# How many demos parse at once (more = faster batches; each big parse peaks ~1-3 GB RAM).
# 6 vCPU / 12 GB box -> 2 is comfortable; raise to 3 if RAM allows.
PARSE_WORKERS=2

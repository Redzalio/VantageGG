# VantageGG — Caddy reverse proxy with automatic HTTPS (Let's Encrypt).
# On the VPS:  cp deploy/Caddyfile /etc/caddy/Caddyfile && systemctl reload caddy
# Requires: Cloudflare A record  vantagegg.com -> <VPS IP>  (DNS only / grey cloud),
# and ports 80 + 443 open. Caddy fetches + renews the cert automatically.

vantagegg.com {
    encode zstd gzip
    request_body {
        max_size 2200MB        # > MAX_UPLOAD_MB so 300-500 MB demos pass through to the app
    }
    # Security header that belongs at the TLS edge (the app sets the rest).
    header Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Long-cache the big, stable map assets (3D geometry ~20MB each + radar PNGs) so repeat visits
    # don't re-download them. The app serves these no-cache by default (right for app.js, wasteful for
    # immutable geometry) -- so we DELETE the upstream Cache-Control and set our own (header_down
    # replaces; otherwise the app's no-cache also rides along and wins). 30 days, revalidates after.
    @mapassets path /static/maps3d/* /static/maps/* /static/img/*
    handle @mapassets {
        reverse_proxy 127.0.0.1:8770 {
            header_down Cache-Control "public, max-age=2592000"   # replaces the app's no-cache for these
        }
    }
    handle {
        reverse_proxy 127.0.0.1:8770
    }
}

# Optional www -> apex redirect. Uncomment AND add a `www` A record in Cloudflare first
# (otherwise Caddy can't get a cert for www and will log errors):
# www.vantagegg.com {
#     redir https://vantagegg.com{uri} permanent
# }

# VantageGG — Caddy reverse proxy with automatic HTTPS (Let's Encrypt).
# On the VPS:  cp deploy/Caddyfile /etc/caddy/Caddyfile && systemctl reload caddy
# Requires: Cloudflare A record  vantagegg.com -> <VPS IP>  (DNS only / grey cloud),
# and ports 80 + 443 open. Caddy fetches + renews the cert automatically.

vantagegg.com {
    encode zstd gzip
    request_body {
        max_size 2200MB        # > MAX_UPLOAD_MB so 300-500 MB demos pass through to the app
    }
    reverse_proxy 127.0.0.1:8770
}

# Optional www -> apex redirect. Uncomment AND add a `www` A record in Cloudflare first
# (otherwise Caddy can't get a cert for www and will log errors):
# www.vantagegg.com {
#     redir https://vantagegg.com{uri} permanent
# }
